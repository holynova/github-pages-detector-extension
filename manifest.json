{
  "manifest_version": 3,
  "name": "GitHub Pages Detector",
  "version": "0.1.0",
  "description": "Detects GitHub Pages for the current GitHub repository and adds a quick open button.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "https://*.github.io/*"
  ],
  "action": {
    "default_title": "GitHub Pages Detector",
    "default_icon": {
      "16": "icons/icon-default-16.png",
      "32": "icons/icon-default-32.png",
      "48": "icons/icon-default-48.png",
      "128": "icons/icon-default-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options.html",
  "icons": {
    "16": "icons/icon-default-16.png",
    "32": "icons/icon-default-32.png",
    "48": "icons/icon-default-48.png",
    "128": "icons/icon-default-128.png"
  }
}
